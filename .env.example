# Promptinear - bring-your-own-LLM configuration
#
# Copy this file to .env and fill in one of the provider blocks below,
# or use `promptinear config set` to manage settings interactively.
#
# Precedence (highest first):
#   1. CLI flags           (--provider, --model, --api-key)
#   2. Environment vars    (this file, if loaded into your shell)
#   3. ~/.promptinear/config.toml
#   4. Defaults (heuristic-only mode, no network required)

# --- Which provider to use --------------------------------------------------
# One of: heuristic | openai | anthropic | gemini | openai-compat
PROMPTINEAR_PROVIDER=heuristic

# Optional: override the model id for the chosen provider.
# PROMPTINEAR_MODEL=gpt-4o-mini

# --- OpenAI (and OpenAI-compatible endpoints) ------------------------------
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
#
# For Ollama:      OPENAI_BASE_URL=http://localhost:11434/v1
# For LM Studio:   OPENAI_BASE_URL=http://localhost:1234/v1
# For OpenRouter:  OPENAI_BASE_URL=https://openrouter.ai/api/v1
# For vLLM:        OPENAI_BASE_URL=http://localhost:8000/v1

# --- Anthropic -------------------------------------------------------------
# ANTHROPIC_API_KEY=sk-ant-...

# --- Google Gemini ---------------------------------------------------------
# GEMINI_API_KEY=...

# --- Networking ------------------------------------------------------------
# Timeout (seconds) for any single provider HTTP call.
# PROMPTINEAR_TIMEOUT=15
